# Copy this file to `.env` and fill in your real API credentials.
# connection_discovery.py reads these at startup; any platform whose
# key is missing or blank is skipped (the rest still run).

# Twitter / X — Bearer Token from https://developer.x.com/
TWITTER_BEARER_TOKEN=your_token

# Farcaster — Neynar API key from https://neynar.com/
FARCASTER_API_KEY=your_key

# LinkedIn — OAuth 2.0 access token from https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=your_token

# DeBank Cloud — API key from https://cloud.debank.com/
DEBANK_API_KEY=your_key
